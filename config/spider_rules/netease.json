{
  "site_id": "netease",
  "site_name": "网易云音乐",
  "base_url": "https://music.163.com",
  "rate_limit_ms": 1500,
  "endpoints": {
    "hot_chart": {
      "url": "https://music.163.com/api/playlist/detail",
      "params": {
        "id": 3778678
      },
      "method": "GET"
    },
    "playlist_detail": {
      "url": "https://music.163.com/api/playlist/detail",
      "method": "GET"
    },
    "artist_info": {
      "url": "https://music.163.com/api/artist/desc",
      "method": "GET"
    }
  },
  "field_mapping": {
    "track_id": "id",
    "title": "name",
    "artist": "artists.0.name",
    "album": "album.name",
    "duration_ms": "duration",
    "play_count": "playCount",
    "cover_url": "album.picUrl"
  },
  "fallback": {
    "use_browser": false,
    "retry_count": 3
  }
}
